# Google Apps Script Web App URL (deploy Code.gs first)
# Example: https://script.google.com/macros/s/xxxxxxxxxxxxxxxx/exec
# IMPORTANT: set BOTH variables in production (Vercel/hosting env settings)
GOOGLE_SCRIPT_URL=

# Public copy used by the browser fallback when server-side sync fails on live
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=

# Public site URL used for email logo/assets (set to your production domain)
# Example: https://odette.ifranchise.in
NEXT_PUBLIC_SITE_URL=

# Resend — https://resend.com
RESEND_API_KEY=

# Verified sender address in Resend
# RESEND_FROM_EMAIL=iFranchise <contact@ifranchise.in>
RESEND_FROM_EMAIL=

# Where new lead notifications are delivered
CONTACT_NOTIFICATION_EMAIL=contact@ifranchise.in

# Google Tag Manager (iFranchise container)
NEXT_PUBLIC_GTM_ID=GTM-P6Z67GFD

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console site verification (HTML meta tag content value)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Set to true to enable GA DebugView in non-development environments
NEXT_PUBLIC_GA_DEBUG=
